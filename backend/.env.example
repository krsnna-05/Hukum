NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Comma-separated list. Example: https://hukum.app,https://www.hukum.app
# Use * only if you intentionally allow any origin.
CORS_ORIGIN=https://your-frontend-domain.com

# Redis (Upstash/Redis Cloud/etc)
REDIS_URL=rediss://default:password@your-upstash-host:6379
